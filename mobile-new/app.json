{
  "expo": {
    "name": "InRage CrossFit",
    "slug": "mobile-new",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "inrage",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.devjulio129.inrage"
    },
    "android": {
      "package": "com.devjulio129.inrage",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0D0D"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "https://inrage-backend.onrender.com",
      "googleClientId": null,
      "googleIosClientId": null,
      "googleAndroidClientId": null
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photoLibraryUsageDescription": "Selecciona tu foto de perfil"
        }
      ],
      "expo-font"
    ]
  }
}
