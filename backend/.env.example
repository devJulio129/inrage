PORT=4000
MONGO_URI=mongodb://localhost:27017/inrage
MONGODB_URI=mongodb://localhost:27017/inrage
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here

# Optional: restrict CORS to your deployed frontends (comma-separated).
# Leave unset to allow all origins (fine for local dev).
# CORS_ORIGIN=https://inrage-admin.onrender.com

# Optional: required only to enable Google Sign-In (Web OAuth Client ID).
# GOOGLE_CLIENT_ID=

# Optional: manual support channel for forgot-password fallback.
SUPPORT_WHATSAPP_NUMBER=528334305108

# Email delivery. Configure either Resend or SMTP.
# RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Inrage <no-reply@inrage.mx>"
PUBLIC_WEB_URL=http://localhost:5173
APP_PUBLIC_URL=inrage://
ADMIN_PUBLIC_URL=http://localhost:5173

# Push notifications (Expo Push API).
PUSH_NOTIFICATIONS_ENABLED=false
# Optional for Expo/EAS tooling if your deployment needs it.
# EXPO_ACCESS_TOKEN=
# Optional shared secret if you expose external job triggers later.
# NOTIFICATION_JOB_SECRET=

# Branch rotating QR check-in.
CHECKIN_QR_SECRET=
CHECKIN_QR_WINDOW_MINUTES_BEFORE=30
CHECKIN_QR_WINDOW_MINUTES_AFTER=15
RESERVATION_CANCEL_MINUTES_BEFORE=30
# Optional QA logs for QR parsing/resolution. Never enable permanently in prod.
CHECKIN_QR_DEBUG=false
